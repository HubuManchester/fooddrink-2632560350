<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:FlavorVault.Converters"
             x:Class="FlavorVault.Controls.CatalogGridCard"
             x:Name="This">

    <ContentView.Resources>
        <converters:StringToUriConverter x:Key="StringToUriConverter" />
        <converters:RarityToColorConverter x:Key="RarityToColorConverter" />
        <converters:TasteToColorConverter x:Key="TasteToColorConverter" />
        <converters:StringNotNullConverter x:Key="StringNotNullConverter" />
    </ContentView.Resources>

    <Border
        StrokeShape="RoundRectangle 12"
        StrokeThickness="0"
        BackgroundColor="{AppThemeBinding Light={DynamicResource Surface}, Dark={DynamicResource Surface}}"
        Padding="0"
        Margin="4">
        <Border.HeightRequest>
            <OnPlatform x:TypeArguments="x:Double">
                <On Platform="WinUI" Value="290" />
                <On Platform="Android" Value="160" />
            </OnPlatform>
        </Border.HeightRequest>
        <Border.Shadow>
            <Shadow Brush="{AppThemeBinding Light=#20000000, Dark=#30000000}"
                    Offset="0,2"
                    Radius="6"
                    Opacity="0.3" />
        </Border.Shadow>

        <Border.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding Source={x:Reference This}, Path=TapCommand}"
                CommandParameter="{Binding}" />
        </Border.GestureRecognizers>

        <Grid RowDefinitions="*,Auto,Auto" RowSpacing="4">

            <!-- 图片区域 -->
            <Grid Grid.Row="0" BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#333333}">
                <Grid.HeightRequest>
                    <OnPlatform x:TypeArguments="x:Double">
                        <On Platform="WinUI" Value="230" />
                        <On Platform="Android" Value="100" />
                    </OnPlatform>
                </Grid.HeightRequest>

                <!-- 底层占位 -->
                <Label Text="&#xf0f5;"
                       FontFamily="fa-solid-900"
                       FontSize="{DynamicResource FontSize30}"
                       TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <!-- 上层图片 -->
                <Image Source="{Binding ImagePath, Converter={StaticResource StringToUriConverter}}"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill"
                       IsVisible="{Binding ImagePath, Converter={StaticResource StringNotNullConverter}}" />

                <!-- 左上角：图鉴编号 -->
                <Border HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Margin="4"
                        Padding="4,2"
                        BackgroundColor="#80000000"
                        StrokeShape="RoundRectangle 4"
                        StrokeThickness="0">
                    <Label Text="{Binding CatalogNumber}"
                           TextColor="White"
                           FontSize="{DynamicResource FontSize9}" />
                </Border>

                <!-- 右上角：稀有度角标 -->
                <Border HorizontalOptions="End"
                        VerticalOptions="Start"
                        BackgroundColor="{Binding Rarity, Converter={StaticResource RarityToColorConverter}}"
                        StrokeShape="RoundRectangle 0,12,0,6"
                        StrokeThickness="0"
                        Padding="6,2">
                    <Label Text="{Binding Rarity}"
                           TextColor="White"
                           FontSize="{DynamicResource FontSize9}"
                           FontAttributes="Bold" />
                </Border>

                <!-- 右下角：星级 -->
                <Border HorizontalOptions="End"
                        VerticalOptions="End"
                        Margin="4"
                        WidthRequest="24"
                        HeightRequest="24"
                        BackgroundColor="#CC000000"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0">
                    <Label Text="{Binding StarRating}"
                           TextColor="#FFD700"
                           FontSize="{DynamicResource FontSize11}"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- 食物名称 -->
            <Label Grid.Row="1"
                   Text="{Binding Name}"
                   FontAttributes="Bold"
                   FontSize="{DynamicResource FontSize13}"
                   LineBreakMode="TailTruncation"
                   MaximumHeightRequest="20"
                   Margin="8,2,8,0"
                   TextColor="{AppThemeBinding Light={DynamicResource TextPrimary}, Dark={DynamicResource TextPrimary}}" />

            <!-- 地区名 + 主味标签 -->
            <HorizontalStackLayout Grid.Row="2"
                                   Spacing="4"
                                   Margin="8,0,8,4"
                                   VerticalOptions="Center">
                <Label Text="{Binding Region}"
                       FontSize="{DynamicResource FontSize10}"
                       TextColor="{AppThemeBinding Light={DynamicResource TextSecondary}, Dark={DynamicResource TextSecondary}}" />

                <Border StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        Padding="6,2"
                        BackgroundColor="{Binding PrimaryTaste, Converter={StaticResource TasteToColorConverter}}"
                        IsVisible="{Binding PrimaryTaste, Converter={StaticResource StringNotNullConverter}}">
                    <Label Text="{Binding PrimaryTaste}"
                           TextColor="White"
                           FontSize="{DynamicResource FontSize9}" />
                </Border>
            </HorizontalStackLayout>

        </Grid>
    </Border>
</ContentView>
