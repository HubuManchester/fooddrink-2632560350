<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlavorVault.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/LightTheme.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 字体大小资源（动态字号系统） -->
            <x:Double x:Key="FontSize7">7</x:Double>
            <x:Double x:Key="FontSize9">9</x:Double>
            <x:Double x:Key="FontSize10">10</x:Double>
            <x:Double x:Key="FontSize11">11</x:Double>
            <x:Double x:Key="FontSize12">12</x:Double>
            <x:Double x:Key="FontSize13">13</x:Double>
            <x:Double x:Key="FontSize14">14</x:Double>
            <x:Double x:Key="FontSize15">15</x:Double>
            <x:Double x:Key="FontSize16">16</x:Double>
            <x:Double x:Key="FontSize18">18</x:Double>
            <x:Double x:Key="FontSize20">20</x:Double>
            <x:Double x:Key="FontSize22">22</x:Double>
            <x:Double x:Key="FontSize24">24</x:Double>
            <x:Double x:Key="FontSize28">28</x:Double>
            <x:Double x:Key="FontSize30">30</x:Double>
            <x:Double x:Key="FontSize32">32</x:Double>
            <x:Double x:Key="FontSize36">36</x:Double>
            <x:Double x:Key="FontSize40">40</x:Double>
            <x:Double x:Key="FontSize44">44</x:Double>
            <x:Double x:Key="FontSize48">48</x:Double>
            <x:Double x:Key="FontSize60">60</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
