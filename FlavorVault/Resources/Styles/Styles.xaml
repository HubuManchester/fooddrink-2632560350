<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="FlavorVault.Resources.Styles.Styles">

    <!-- ============ 全局 Page 样式 ============ -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor"
                Value="{DynamicResource Background}" />
    </Style>

    <!-- ============ 全局 Shell 样式 ============ -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor"
                Value="{DynamicResource Surface}" />
        <Setter Property="Shell.ForegroundColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="Shell.TitleColor"
                Value="{DynamicResource TextPrimary}" />
        <Setter Property="Shell.DisabledColor"
                Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
        <Setter Property="Shell.UnselectedColor"
                Value="{DynamicResource Gray500}" />
        <Setter Property="Shell.TabBarBackgroundColor"
                Value="{DynamicResource Surface}" />
        <Setter Property="Shell.TabBarForegroundColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="Shell.TabBarTitleColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor"
                Value="{DynamicResource Gray500}" />
    </Style>

    <!-- ============ Label 样式 ============ -->
    <Style TargetType="Label" ApplyToDerivedTypes="True">
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <Style x:Key="LabelLarge" TargetType="Label">
        <Setter Property="FontSize" Value="{DynamicResource FontSize24}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style x:Key="LabelMedium" TargetType="Label">
        <Setter Property="FontSize" Value="{DynamicResource FontSize18}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style x:Key="LabelBody" TargetType="Label">
        <Setter Property="FontSize" Value="{DynamicResource FontSize15}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style x:Key="LabelCaption" TargetType="Label">
        <Setter Property="FontSize" Value="{DynamicResource FontSize12}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="TextColor"
                Value="{DynamicResource TextSecondary}" />
    </Style>

    <Style x:Key="LabelSection" TargetType="Label">
        <Setter Property="FontSize" Value="{DynamicResource FontSize16}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- ============ Button 样式 ============ -->
    <Style TargetType="Button" ApplyToDerivedTypes="True">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize14}" />
        <Setter Property="BackgroundColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="BackgroundColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize15}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="ButtonAccent" TargetType="Button">
        <Setter Property="BackgroundColor"
                Value="{DynamicResource Accent}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize15}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="ButtonOutline" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="BorderColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="TextColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize14}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"
                Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize14}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <!-- ============ Entry / Editor 样式 ============ -->
    <Style TargetType="Entry" ApplyToDerivedTypes="True">
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
        <Setter Property="PlaceholderColor"
                Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize15}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style TargetType="Editor" ApplyToDerivedTypes="True">
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
        <Setter Property="PlaceholderColor"
                Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize15}" />
    </Style>

    <!-- ============ Picker 样式 ============ -->
    <Style TargetType="Picker" ApplyToDerivedTypes="True">
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
        <Setter Property="TitleColor"
                Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize15}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <!-- ============ 卡片样式 ============ -->
    <Style x:Key="CardStyle" TargetType="Frame">
        <Setter Property="BackgroundColor"
                Value="{DynamicResource CardBackground}" />
        <Setter Property="BorderColor"
                Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray300}}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="CardStyleFlat" TargetType="Frame">
        <Setter Property="BackgroundColor"
                Value="{DynamicResource CardBackground}" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ============ 胶囊标签样式 ============ -->
    <Style x:Key="CapsuleLabelStyle" TargetType="Frame">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="BackgroundColor"
                Value="{DynamicResource PrimaryLight}" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

    <Style x:Key="CapsuleLabelTextStyle" TargetType="Label">
        <Setter Property="FontSize" Value="{DynamicResource FontSize11}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="TextColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="CapsuleLabelAccentStyle" TargetType="Frame">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="BackgroundColor"
                Value="{DynamicResource AccentLight}" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

    <Style x:Key="CapsuleLabelAccentTextStyle" TargetType="Label">
        <Setter Property="FontSize" Value="{DynamicResource FontSize11}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="TextColor"
                Value="{DynamicResource Accent}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- ============ FA 图标默认样式 ============ -->
    <Style x:Key="FAIconStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="fa-solid-900" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize20}" />
        <Setter Property="TextColor"
                Value="{DynamicResource TextSecondary}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style x:Key="FAIconPrimaryStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="fa-solid-900" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize20}" />
        <Setter Property="TextColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style x:Key="FAIconLargeStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="fa-solid-900" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize32}" />
        <Setter Property="TextColor"
                Value="{DynamicResource TextSecondary}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- ============ 分隔线样式 ============ -->
    <Style x:Key="DividerStyle" TargetType="BoxView">
        <Setter Property="Color"
                Value="{DynamicResource Divider}" />
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!-- ============ 进度条样式 ============ -->
    <Style x:Key="ProgressBarTrack" TargetType="Frame">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray300}}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HeightRequest" Value="8" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="BorderColor" Value="Transparent" />
    </Style>

    <Style x:Key="ProgressBarFill" TargetType="Frame">
        <Setter Property="BackgroundColor"
                Value="{DynamicResource Primary}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HeightRequest" Value="8" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="BorderColor" Value="Transparent" />
    </Style>

    <!-- ============ ImageButton 样式 ============ -->
    <Style TargetType="ImageButton" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- ============ RefreshView 样式 ============ -->
    <Style TargetType="RefreshView" ApplyToDerivedTypes="True">
        <Setter Property="RefreshColor"
                Value="{DynamicResource Primary}" />
    </Style>

    <!-- ============ SearchBar 样式 ============ -->
    <Style TargetType="SearchBar" ApplyToDerivedTypes="True">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize15}" />
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
        <Setter Property="PlaceholderColor"
                Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <!-- ============ CheckBox 样式 ============ -->
    <Style TargetType="CheckBox" ApplyToDerivedTypes="True">
        <Setter Property="Color"
                Value="{DynamicResource Primary}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <!-- ============ DatePicker 样式 ============ -->
    <Style TargetType="DatePicker" ApplyToDerivedTypes="True">
        <Setter Property="TextColor"
                Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize15}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <!-- ============ ScrollView 样式 ============ -->
    <Style TargetType="ScrollView" ApplyToDerivedTypes="True">
        <Setter Property="VerticalScrollBarVisibility" Value="Default" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Default" />
    </Style>

    <!-- ============ CollectionView 样式 ============ -->
    <Style TargetType="CollectionView" ApplyToDerivedTypes="True">
        <Setter Property="SelectionMode" Value="None" />
    </Style>

    <!-- ============ ActivityIndicator 样式 ============ -->
    <Style TargetType="ActivityIndicator" ApplyToDerivedTypes="True">
        <Setter Property="Color"
                Value="{DynamicResource Primary}" />
    </Style>

</ResourceDictionary>
