<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FlavorVault.ViewModels"
             xmlns:converters="clr-namespace:FlavorVault.Converters"
             x:Class="FlavorVault.Views.LoginPage"
             x:DataType="viewmodels:LoginViewModel"
             Title="登录"
             BackgroundColor="{DynamicResource Background}">

    <ContentPage.Resources>
        <converters:BoolToTextConverter x:Key="BoolToTextConverter"
                                        TrueText="&#xf06e;"
                                        FalseText="&#xf070;" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="32,60,32,32"
          RowSpacing="0">

        <VerticalStackLayout Grid.Row="0"
                             Spacing="8"
                             HorizontalOptions="Center"
                             Margin="0,0,0,40">
            <Label Text="&#xf0f4;"
                   FontFamily="fa-solid-900"
                   FontSize="{DynamicResource FontSize48}"
                   TextColor="{DynamicResource Primary}"
                   HorizontalOptions="Center" />
            <Label Text="味藏"
                   FontSize="{DynamicResource FontSize32}"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource TextPrimary}"
                   HorizontalOptions="Center" />
            <Label Text="登录你的美食图鉴账号"
                   FontSize="{DynamicResource FontSize14}"
                   TextColor="{DynamicResource TextSecondary}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1"
                             Spacing="16"
                             VerticalOptions="Start">

            <Border BackgroundColor="{DynamicResource Surface}"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1"
                    Stroke="{DynamicResource Gray300}"
                    Padding="16,12">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                    <Label Text="&#xf007;"
                           FontFamily="fa-solid-900"
                           FontSize="{DynamicResource FontSize16}"
                           TextColor="{DynamicResource TextSecondary}"
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           Placeholder="用户名"
                           Text="{Binding Username}"
                           FontSize="{DynamicResource FontSize16}"
                           TextColor="{DynamicResource TextPrimary}"
                           PlaceholderColor="{DynamicResource TextSecondary}"
                           ReturnType="Next"
                           ClearButtonVisibility="WhileEditing" />
                </Grid>
            </Border>

            <Border BackgroundColor="{DynamicResource Surface}"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1"
                    Stroke="{DynamicResource Gray300}"
                    Padding="16,12">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">
                    <Label Text="&#xf023;"
                           FontFamily="fa-solid-900"
                           FontSize="{DynamicResource FontSize16}"
                           TextColor="{DynamicResource TextSecondary}"
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           Placeholder="密码"
                           Text="{Binding Password}"
                           FontSize="{DynamicResource FontSize16}"
                           TextColor="{DynamicResource TextPrimary}"
                           PlaceholderColor="{DynamicResource TextSecondary}"
                           IsPassword="{Binding IsPasswordObscured}"
                           ReturnType="Done"
                           ReturnCommand="{Binding LoginCommand}" />
                    <Border Grid.Column="2"
                            BackgroundColor="Transparent"
                            StrokeThickness="0"
                            Padding="4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding IsPasswordObscured, Converter={StaticResource BoolToTextConverter}}"
                               FontFamily="fa-solid-900"
                               FontSize="{DynamicResource FontSize14}"
                               TextColor="{DynamicResource TextSecondary}"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   FontSize="{DynamicResource FontSize13}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}"
                   Margin="4,0,0,0" />

            <Button Text="登录"
                    FontSize="{DynamicResource FontSize16}"
                    FontAttributes="Bold"
                    BackgroundColor="{DynamicResource Primary}"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="25"
                    Command="{Binding LoginCommand}"
                    Margin="0,8,0,0" />
        </VerticalStackLayout>

        <HorizontalStackLayout Grid.Row="2"
                               HorizontalOptions="Center"
                               Spacing="4"
                               VerticalOptions="End">
            <Label Text="还没有账号？"
                   FontSize="{DynamicResource FontSize14}"
                   TextColor="{DynamicResource TextSecondary}"
                   VerticalOptions="Center" />
            <Label Text="立即注册"
                   FontSize="{DynamicResource FontSize14}"
                   TextColor="{DynamicResource Primary}"
                   FontAttributes="Bold"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
